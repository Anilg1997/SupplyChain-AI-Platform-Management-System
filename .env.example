# ============================================
# SupplyChain AI Platform - Environment Variables
# ============================================

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=SupplyChain@2024
POSTGRES_DB=supplychainai
POSTGRES_PORT=5432

# --- MongoDB ---
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=Mongo@2024
MONGO_PORT=27017

# --- Redis ---
REDIS_PASSWORD=Redis@2024
REDIS_PORT=6379

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181

# --- Service Registry ---
EUREKA_SERVER_URL=http://service-registry:8761/eureka

# --- JWT ---
JWT_SECRET=SupplyChainAI_JWT_Min32CharSecret_2024
JWT_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_DAYS=7

# --- AI/LLM (Ollama) ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_PORT=11434
OLLAMA_CHAT_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- PGVector ---
PGVECTOR_DATABASE=supplychainai
PGVECTOR_USERNAME=postgres
PGVECTOR_PASSWORD=SupplyChain@2024

# --- Monitoring ---
ZIPKIN_PORT=9411
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin
KAFKA_UI_PORT=8090
MONGO_EXPRESS_PORT=8091
PGADMIN_EMAIL=admin@supplychainai.com
PGADMIN_PASSWORD=SupplyChain@2024
PGADMIN_PORT=5050

# --- Mail (mock) ---
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=

# --- App Config ---
SPRING_PROFILES_ACTIVE=docker
JAVA_OPTS=-Xms256m -Xmx512m

# --- MCP Config ---
MCP_SERVER_FILESYSTEM_ENABLED=true
MCP_SERVER_GIT_ENABLED=true
MCP_SERVER_POSTGRES_ENABLED=true
MCP_SERVER_KAFKA_ENABLED=true